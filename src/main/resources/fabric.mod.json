{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": ["${author}"],
  "contact": {},
  "license": "${license}",
  "icon": "assets/${mod_path}/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "${maven_group}.${mod_path}.client.${clean_mod_name}DataGenerator"
    ],
    "main": [
      "${maven_group}.${mod_path}.${clean_mod_name}"
    ]
  },
  "mixins": [
    "${mod_path}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": ">=${minecraft_version}"
  },
  "suggests": {
    "fzzy-config": ">=${fzzy_config_version}"
  }
}
